---
import css from "./Pokemon.module.css";

interface Props {
  url: string;
  name: string;
}

const { url, name } = Astro.props;

const pokemon_id = url.split("/").at(-2);

const img_url = `https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/other/official-artwork/${pokemon_id}.png`;
---

<a class={css.pokemon} href={`http://localhost:4321/${name}`}>
  <h2>{name}</h2>
  <img src={img_url} alt={name} />
</a>
