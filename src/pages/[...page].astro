---
import IndexView from "../views/IndexView/IndexView.astro";
import type { PokemonsRes } from "../types/pokemons_res";
import type { GetStaticPaths } from "astro";
import { POKEMONS_URL } from "@api_pokemons/urls";

export const getStaticPaths = (async ({ paginate }) => {
  const pokemons_fetch = await fetch(POKEMONS_URL);
  const res_pokemons = (await pokemons_fetch.json()) as PokemonsRes;

  return paginate(res_pokemons.results, { pageSize: 20 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<IndexView page={page} />
