---
import type { GetStaticPaths } from "astro";
import type { PokemonsRes } from "../types/pokemons_res";
import PokemonView from "@views/PokemonView/PokemonView.astro";
import { POKEMONS_URL } from "@api_pokemons/urls";

export const getStaticPaths = (async () => {
  const pokemons_fetch = await fetch(POKEMONS_URL);
  const res_pokemons = (await pokemons_fetch.json()) as PokemonsRes;

  const pages = res_pokemons.results.map((item) => {
    return { params: { name: item.name }, props: { url: item.url } };
  });

  return pages;
}) satisfies GetStaticPaths;
---

<PokemonView name={Astro.params.name} url={Astro.props.url} />
