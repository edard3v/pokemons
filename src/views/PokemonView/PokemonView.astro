---
import { get_pokemon_song } from "@api_pokemons/utils/get_pokemon_song";
import css from "./PokemonView.module.css";
import Pokemon from "@components/Pokemon/Pokemon.astro";
import Layout from "@layouts/Layout.astro";
import { get_pokemon_img } from "@api_pokemons/utils/get_pokemon_img";
import { get_pokemon_id } from "@api_pokemons/utils/get_pokemon_id";
import { capitalize } from "@utils/capitalize";
import { Icon } from "astro-icon/components";

interface Props {
  name: string;
  url: string;
}

const { name, url } = Astro.props;

const pokemon_song_url = get_pokemon_song(url);
const pokemon_img_url = get_pokemon_img(url);
const pokemon_id = get_pokemon_id(url);
const pokemon_name = capitalize(name);

const pokemon_description = `Información sobre el pokemon ${pokemon_name}`;
---

<Layout
  title={`Pokemon #${pokemon_id} - ${pokemon_name}`}
  img_url={pokemon_img_url}
  description={pokemon_description}
>
  <main class={css.pokemon_view}>
    <div id="pokemon_card" class={css.card} data-name={name} data-img={pokemon_img_url}>
      <button id="wrapper_like" class={css.wrapper_like}>
        <Icon
          id="like"
          class:list={[css.like, "hidden"]}
          name={"like"}
          size={30}
          color={"royalblue"}
        />
        <Icon
          id="like_out"
          class:list={[css.like_out]}
          name={"like_out"}
          size={30}
          color={"royalblue"}
        />
      </button>
      <Pokemon cls={css.pokemon} name={name} url={url} />
      <audio src={pokemon_song_url} controls></audio>
      <a href="javascript:history.back()">regresar</a>
    </div>
  </main>
</Layout>

<script>
  import { is_favorite_pokemons } from "@local_storage/is_favorite_pokemons";
  import { toggle_favorite_pokemons } from "@local_storage/toggle_favorite_pokemons";

  document.addEventListener("astro:page-load", () => {
    const pokemon_card = document.querySelector("#pokemon_card") as HTMLElement;
    const wrapper_like = document.querySelector("#wrapper_like") as HTMLElement;
    const icon_like = document.querySelector("#like") as HTMLElement;
    const icon_like_out = document.querySelector("#like_out") as HTMLElement;

    const name = pokemon_card.dataset.name!;

    if (is_favorite_pokemons(name)) {
      icon_like.classList.remove("hidden");
      icon_like_out.classList.add("hidden");
    }

    wrapper_like?.addEventListener("click", () => {
      icon_like?.classList.toggle("hidden");
      icon_like_out?.classList.toggle("hidden");

      const img = pokemon_card.dataset.img!;

      toggle_favorite_pokemons({ name, img });
    });
  });
</script>
